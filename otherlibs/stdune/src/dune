(library
 (name stdune)
 (public_name stdune)
 (synopsis
  "Standard library of Dune.\nThis library offers no backwards compatibility guarantees. Use at your own risk.")
 (libraries
  unix
  csexp
  threads
  threads.posix
  (re_export top-closure)
  (re_export ordering)
  (re_export dyn)
  (re_export pp)
  fs-io)
 (root_module root)
 (library_flags
  (:include ../flags/sexp))
 (foreign_stubs
  (language c)
  (names spawn_stubs)
  (flags
   (:standard
    (:include spawn_flags.sexp))))
 (foreign_stubs
  (language c)
  (names
   dune_flock
   readdir
   wait4_stubs
   platform_stubs
   copyfile_stubs
   signal_stubs
   time_stubs)))

(rule
 (target spawn_flags.sexp)
 (enabled_if
  (= %{os_type} "Win32"))
 (action
  (with-stdout-to
   %{target}
   (echo "(-DUNICODE -D_UNICODE)"))))

(rule
 (target spawn_flags.sexp)
 (enabled_if
  (<> %{os_type} "Win32"))
 (action
  (with-stdout-to
   %{target}
   (echo "()"))))
