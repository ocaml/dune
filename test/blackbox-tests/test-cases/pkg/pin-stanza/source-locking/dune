(cram
 (setup_scripts source-locking-helpers.sh))

(rule
 (alias runtest)
 (deps source-locking-helpers.sh)
 (action
  (run %{bin:bash} -n %{deps})))

(rule
 (alias runtest)
 (enabled_if %{bin-available:shellcheck})
 (deps source-locking-helpers.sh)
 (action
  (run %{bin:shellcheck} -s bash %{deps})))
